<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:open-bpmn="http://open-bpmn.org/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" exporter="Antigravity IDE - BRISMAR" exporterVersion="3.0" id="Definitions_GestionIncidenciasTI" targetNamespace="http://brismar.com/bpmn/incidencias-ti">
  <bpmn:collaboration id="Collaboration_GestionIncidencias">
    <bpmn:participant id="Pool_Brismar" name="BRISMAR — Gestión de Incidencias TI" processRef="Process_GestionIncidencias">
      <bpmn:documentation id="documentation_puIBhw"/>
    </bpmn:participant>
    <bpmn:participant id="participant_FCvP9Q" name="Default Process" processRef="process_d0gN0w"/>
  </bpmn:collaboration>
  <bpmn:process id="Process_GestionIncidencias" isExecutable="false" name="Gestión de Incidencias TI - BRISMAR" processType="Private">
    <bpmn:documentation>
      Proceso de gestión de incidencias TI con 3 carriles:
      - Operario: reporta y confirma la solución final.
      - Técnico TI (N1): clasifica y resuelve incidencias bajas.
      - Jefe TI (N2): gestiona prioridades media/alta y escala al proveedor externo.
      Cuando se escala al proveedor, el proceso interno de BRISMAR termina.
      Si el Operario rechaza la solución, el Jefe TI retoma (loop limpio por encabezado del pool).
    </bpmn:documentation>
    <bpmn:laneSet id="LaneSet_Principal">
      <bpmn:lane id="Lane_Operario" name="Operario (Reportante)">
        <bpmn:documentation id="documentation_qyideA"/>
        <bpmn:flowNodeRef>StartEvent_IncidenciaDetectada</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReportarIncidencia</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ConfirmarSolucion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SolucionConfirmada</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_TicketCerrado</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_TecnicoTI" name="Técnico TI (Nivel 1)">
        <bpmn:documentation id="documentation_gciqPg"/>
        <bpmn:flowNodeRef>Task_RecopilarInformacion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ClasificarIncidencia</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_DeterminarPrioridad</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Solucionar</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_JefeTI" name="Jefe TI (Nivel 2)">
        <bpmn:documentation id="documentation_AdHW1A"/>
        <bpmn:flowNodeRef>Gateway_Nivel2Resuelve</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ResolverYNotificar</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Atender</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_EscaladoProveedor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EscalarProveedor</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:sequenceFlow id="Flow_Inicio_Reportar" sourceRef="StartEvent_IncidenciaDetectada" targetRef="Task_ReportarIncidencia">
      <bpmn:documentation id="documentation_LhwbFA"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Reportar_Recopilar" sourceRef="Task_ReportarIncidencia" targetRef="Task_RecopilarInformacion">
      <bpmn:documentation id="documentation_LGwWgQ"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Recopilar_Clasificar" sourceRef="Task_RecopilarInformacion" targetRef="Task_ClasificarIncidencia">
      <bpmn:documentation id="documentation_Vw9URQ"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Clasificar_Prioridad" sourceRef="Task_ClasificarIncidencia" targetRef="Gateway_DeterminarPrioridad">
      <bpmn:documentation id="documentation_TrcWOg"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Prioridad_MediaAlta" name="MEDIA / ALTA" sourceRef="Gateway_DeterminarPrioridad" targetRef="Task_Atender">
      <bpmn:documentation id="documentation_CmcknA"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Confirmada_No" name="No / Reintentar" sourceRef="Gateway_SolucionConfirmada" targetRef="Task_Atender">
      <bpmn:documentation id="documentation_cuQalw"/>
    </bpmn:sequenceFlow>
    <bpmn:startEvent id="StartEvent_IncidenciaDetectada" name="Incidencia detectada">
      <bpmn:documentation id="documentation_5qLwIQ"/>
      <bpmn:outgoing>Flow_Inicio_Reportar</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_ReportarIncidencia" name="Reportar Incidencia">
      <bpmn:documentation>El operario describe la incidencia, adjunta evidencia y la registra en el sistema de tickets.</bpmn:documentation>
      <bpmn:incoming>Flow_Inicio_Reportar</bpmn:incoming>
      <bpmn:outgoing>Flow_Reportar_Recopilar</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_Atender_Nivel2Gateway" sourceRef="Task_Atender" targetRef="Gateway_Nivel2Resuelve">
      <bpmn:documentation id="documentation_8qnAgw"/>
    </bpmn:sequenceFlow>
    <bpmn:userTask id="Task_RecopilarInformacion" name="Recopilar información de la incidencia">
      <bpmn:documentation>El técnico recopila logs, capturas de pantalla y contexto del entorno afectado para documentar la incidencia.</bpmn:documentation>
      <bpmn:incoming>Flow_Reportar_Recopilar</bpmn:incoming>
      <bpmn:outgoing>Flow_Recopilar_Clasificar</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ClasificarIncidencia" name="Clasificar incidencia&#10;(impacto + urgencia)">
      <bpmn:documentation>El técnico evalúa el impacto operativo y la urgencia para asignar prioridad: BAJA, MEDIA o ALTA.</bpmn:documentation>
      <bpmn:incoming>Flow_Recopilar_Clasificar</bpmn:incoming>
      <bpmn:outgoing>Flow_Clasificar_Prioridad</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway gatewayDirection="Diverging" id="Gateway_Nivel2Resuelve" name="¿Nivel 2 resuelve?">
      <bpmn:documentation id="documentation_VJb04A"/>
      <bpmn:incoming>Flow_Atender_Nivel2Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Nivel2Si</bpmn:outgoing>
      <bpmn:outgoing>Flow_Nivel2No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_Solucionar_Confirmar" sourceRef="Task_Solucionar" targetRef="Task_ConfirmarSolucion">
      <bpmn:documentation id="documentation_E0X63w"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Resolver_Confirmar" sourceRef="Task_ResolverYNotificar" targetRef="Task_ConfirmarSolucion">
      <bpmn:documentation id="documentation_GE0Kvg"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Confirmar_Gateway" sourceRef="Task_ConfirmarSolucion" targetRef="Gateway_SolucionConfirmada">
      <bpmn:documentation id="documentation_4kJzVw"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Confirmada_Si" name="Sí" sourceRef="Gateway_SolucionConfirmada" targetRef="EndEvent_TicketCerrado">
      <bpmn:documentation id="documentation_Vb1hnQ"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Prioridad_Baja" name="BAJA" sourceRef="Gateway_DeterminarPrioridad" targetRef="Task_Solucionar">
      <bpmn:documentation id="documentation_OkysVQ"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Nivel2Si" name="Sí" sourceRef="Gateway_Nivel2Resuelve" targetRef="Task_ResolverYNotificar">
      <bpmn:documentation id="documentation_pXsJlw"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Nivel2No" name="No" sourceRef="Gateway_Nivel2Resuelve" targetRef="Task_EscalarProveedor">
      <bpmn:documentation id="documentation_NxSUyg"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Escalar_Fin" sourceRef="Task_EscalarProveedor" targetRef="EndEvent_EscaladoProveedor">
      <bpmn:documentation id="documentation_6KxuZg"/>
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway gatewayDirection="Diverging" id="Gateway_DeterminarPrioridad" name="¿Cuál es la prioridad?">
      <bpmn:documentation id="documentation_2x03Jw"/>
      <bpmn:incoming>Flow_Clasificar_Prioridad</bpmn:incoming>
      <bpmn:outgoing>Flow_Prioridad_Baja</bpmn:outgoing>
      <bpmn:outgoing>Flow_Prioridad_MediaAlta</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ResolverYNotificar" name="Resolver y notificar al Operario">
      <bpmn:documentation>El Jefe TI aplica la solución y notifica al Operario para que confirme que el servicio fue restaurado.</bpmn:documentation>
      <bpmn:incoming>Flow_Nivel2Si</bpmn:incoming>
      <bpmn:outgoing>Flow_Resolver_Confirmar</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Solucionar" name="Solucionar incidencia&#10;(Nivel 1)">
      <bpmn:documentation>El Técnico TI resuelve directamente incidencias de prioridad BAJA. Notifica al Operario para confirmación.</bpmn:documentation>
      <bpmn:incoming>Flow_Prioridad_Baja</bpmn:incoming>
      <bpmn:outgoing>Flow_Solucionar_Confirmar</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ConfirmarSolucion" name="Confirmar solución">
      <bpmn:documentation>El operario verifica en su entorno que la incidencia fue resuelta. Confirma o rechaza la solución.</bpmn:documentation>
      <bpmn:incoming>Flow_Solucionar_Confirmar</bpmn:incoming>
      <bpmn:incoming>Flow_Resolver_Confirmar</bpmn:incoming>
      <bpmn:outgoing>Flow_Confirmar_Gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway gatewayDirection="Diverging" id="Gateway_SolucionConfirmada" name="¿Solución confirmada?">
      <bpmn:documentation id="documentation_okI6ww"/>
      <bpmn:incoming>Flow_Confirmar_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Confirmada_Si</bpmn:outgoing>
      <bpmn:outgoing>Flow_Confirmada_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_Atender" name="Atender incidencia&#10;(Nivel 2)">
      <bpmn:documentation>El Jefe TI recibe incidencias MEDIA o ALTA (o rechazos del Operario) y las gestiona o decide escalar.</bpmn:documentation>
      <bpmn:incoming>Flow_Prioridad_MediaAlta</bpmn:incoming>
      <bpmn:incoming>Flow_Confirmada_No</bpmn:incoming>
      <bpmn:outgoing>Flow_Atender_Nivel2Gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_EscaladoProveedor" name="Escalado a Proveedor&#10;(Proceso interno cerrado)">
      <bpmn:documentation>El proceso interno de BRISMAR concluye. El seguimiento pasa al proveedor externo fuera del alcance de este proceso.</bpmn:documentation>
      <bpmn:incoming>Flow_Escalar_Fin</bpmn:incoming>
      <bpmn:terminateEventDefinition id="TerminateEventDef_Proveedor"/>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_TicketCerrado" name="Ticket cerrado y archivado">
      <bpmn:documentation id="documentation_1aVv3Q"/>
      <bpmn:incoming>Flow_Confirmada_Si</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Task_EscalarProveedor" name="Escalar a Proveedor Externo&#10;y documentar ticket">
      <bpmn:documentation>El Jefe TI escala formalmente la incidencia al proveedor externo, documenta el ticket con toda la información recopilada y cierra el seguimiento interno.</bpmn:documentation>
      <bpmn:incoming>Flow_Nivel2No</bpmn:incoming>
      <bpmn:outgoing>Flow_Escalar_Fin</bpmn:outgoing>
    </bpmn:userTask>
  </bpmn:process>
  <bpmn:process definitionalCollaborationRef="Collaboration_GestionIncidencias" id="process_d0gN0w" name="Default Process" processType="Public">
    <bpmn:documentation id="documentation_1eHJPA"/>
    <bpmn:extensionElements>
      <open-bpmn:auto-align/>
    </bpmn:extensionElements>
  </bpmn:process>
