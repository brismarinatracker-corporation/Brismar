        <bpmndi:BPMNLabel>
          <dc:Bounds x="616" y="627" width="48" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_DeterminarPrioridad" bpmnElement="Gateway_DeterminarPrioridad" isMarkerVisible="true">
        <dc:Bounds x="645" y="395" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="704.5" y="406.5" width="57" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ResolverYNotificar" bpmnElement="Task_ResolverYNotificar">
        <dc:Bounds x="830" y="555" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Solucionar" bpmnElement="Task_Solucionar">
        <dc:Bounds x="720" y="287" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_ConfirmarSolucion" bpmnElement="Task_ConfirmarSolucion">
        <dc:Bounds x="930" y="117" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_SolucionConfirmada" bpmnElement="Gateway_SolucionConfirmada" isMarkerVisible="true">
        <dc:Bounds x="1115" y="132" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1110" y="189" width="61" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Atender" bpmnElement="Task_Atender">
        <dc:Bounds x="460" y="555" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent_EscaladoProveedor" bpmnElement="EndEvent_EscaladoProveedor">
        <dc:Bounds x="1422" y="692" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1400" y="735" width="81" height="53" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent_TicketCerrado" bpmnElement="EndEvent_TicketCerrado" bioc:stroke="#831311" bioc:fill="#ffcdd2" color:background-color="#ffcdd2" color:border-color="#831311">
        <dc:Bounds x="1422" y="139" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1401" y="182" width="79" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_EscalarProveedor" bpmnElement="Task_EscalarProveedor">
        <dc:Bounds x="620" y="694" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_Inicio_Reportar" bpmnElement="Flow_Inicio_Reportar">
        <di:waypoint x="198" y="130" />
        <di:waypoint x="250" y="130" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Reportar_Recopilar" bpmnElement="Flow_Reportar_Recopilar">
        <di:waypoint x="310" y="170" />
        <di:waypoint x="310" y="260" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Recopilar_Clasificar" bpmnElement="Flow_Recopilar_Clasificar">
        <di:waypoint x="310" y="340" />
        <di:waypoint x="310" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Clasificar_Prioridad" bpmnElement="Flow_Clasificar_Prioridad">
        <di:waypoint x="370" y="420" />
        <di:waypoint x="645" y="420" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Prioridad_MediaAlta" bpmnElement="Flow_Prioridad_MediaAlta">
        <di:waypoint x="670" y="445" />
        <di:waypoint x="670" y="460" />
        <di:waypoint x="520" y="460" />
        <di:waypoint x="520" y="555" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="535" y="445" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Confirmada_No" bpmnElement="Flow_Confirmada_No">
        <di:waypoint x="1140" y="132" />
        <di:waypoint x="1140" y="90" />
        <di:waypoint x="400" y="90" />
        <di:waypoint x="400" y="595" />
        <di:waypoint x="460" y="595" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="814" y="73" width="75" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Atender_Nivel2Gateway" bpmnElement="Flow_Atender_Nivel2Gateway">
        <di:waypoint x="580" y="595" />
        <di:waypoint x="645" y="595" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Solucionar_Confirmar" bpmnElement="Flow_Solucionar_Confirmar">
        <di:waypoint x="780" y="287" />
        <di:waypoint x="780" y="157" />
        <di:waypoint x="930" y="157" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Resolver_Confirmar" bpmnElement="Flow_Resolver_Confirmar">
        <di:waypoint x="890" y="555" />
        <di:waypoint x="890" y="180" />
        <di:waypoint x="930" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Confirmar_Gateway" bpmnElement="Flow_Confirmar_Gateway">
        <di:waypoint x="1050" y="157" />
        <di:waypoint x="1115" y="157" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Confirmada_Si" bpmnElement="Flow_Confirmada_Si">
        <di:waypoint x="1165" y="157" />
        <di:waypoint x="1422" y="157" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1286" y="140" width="11" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Prioridad_Baja" bpmnElement="Flow_Prioridad_Baja">
        <di:waypoint x="670" y="395" />
        <di:waypoint x="670" y="327" />
        <di:waypoint x="720" y="327" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="625" y="363" width="29" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Nivel2Si" bpmnElement="Flow_Nivel2Si">
        <di:waypoint x="695" y="595" />
        <di:waypoint x="830" y="595" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="753" y="578" width="11" height="14" />
        </bpmndi:BPMNLabel>
