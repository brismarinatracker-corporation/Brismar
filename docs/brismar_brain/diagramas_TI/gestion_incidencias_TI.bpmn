      <bpmndi:BPMNEdge bpmnElement="Flow_Prioridad_Baja" id="Edge_Flow_Prioridad_Baja">
        <di:waypoint x="670.0" y="395.0"/>
        <di:waypoint x="670.0" y="327.0"/>
        <di:waypoint x="720.0" y="327.0"/>
