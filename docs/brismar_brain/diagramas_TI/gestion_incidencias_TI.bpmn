        <di:waypoint x="670" y="620" />
        <di:waypoint x="670" y="694" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="683" y="653" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Escalar_Fin" bpmnElement="Flow_Escalar_Fin">
        <di:waypoint x="740" y="738" />
        <di:waypoint x="1076" y="738" />
        <di:waypoint x="1076" y="704" />
        <di:waypoint x="1423" y="704" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
