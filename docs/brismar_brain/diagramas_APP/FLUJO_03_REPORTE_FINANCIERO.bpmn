<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_Reporte" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_Reporte">
    <bpmn:participant id="Participant_Reporte" name="Generación de Reportes Financieros y Cierre de Caja" processRef="Process_Reporte" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Reporte" name="Proceso de Reporte Financiero Web" isExecutable="false">
    <bpmn:documentation>Este proceso describe cómo el personal de oficina en tierra consulta el consolidado de capturas y gastos del periodo, visualizando estadísticas reactivas en pantalla o descargando un informe formal PDF generado al vuelo en el servidor Node.js/Express.</bpmn:documentation>
    <bpmn:laneSet id="LaneSet_Reporte">
      <bpmn:lane id="Lane_User" name="Administrador de Oficina (Usuario)">
        <bpmn:flowNodeRef>StartEvent_Reporte</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AccessPanel</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FillFilters</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SelectAction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_ShowWeb</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_FailReport</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_DownloadPDF</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Web" name="Dashboard Web (Frontend)">
        <bpmn:flowNodeRef>Task_RenderError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RenderStats</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_TriggerDownload</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Server" name="Servidor API Web (Backend Node/Express)">
        <bpmn:flowNodeRef>Task_QueryDB</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_StreamPDF</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CompilePDF</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ResponseSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_QueryCheck</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_DB" name="Base de Datos Central (Supabase / Postgres)">
        <bpmn:flowNodeRef>DataStore_Reporte</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_DBSelect</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Reporte" name="Iniciar Auditoría de Periodo">
      <bpmn:outgoing>Flow_Start</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_AccessPanel" name="Acceder al Panel Web de Brismar">
      <bpmn:incoming>Flow_Start</bpmn:incoming>
      <bpmn:outgoing>Flow_ToFilters</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_FillFilters" name="Seleccionar Rango de Fechas y Bahía">
      <bpmn:incoming>Flow_ToFilters</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSelection</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_SelectAction" name="¿Qué acción desea realizar?">
      <bpmn:incoming>Flow_ToSelection</bpmn:incoming>
      <bpmn:outgoing>Flow_ToStats</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToPDF</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:dataStoreReference id="DataStore_Reporte" name="PostgreSQL (Supabase DB)" />
    <bpmn:endEvent id="EndEvent_ShowWeb" name="Visualizado en Pantalla">
      <bpmn:incoming>Flow_EndWeb</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_FailReport" name="Fallo de Conciliación">
      <bpmn:incoming>Flow_EndErr</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start" sourceRef="StartEvent_Reporte" targetRef="Task_AccessPanel" />
    <bpmn:sequenceFlow id="Flow_ToFilters" sourceRef="Task_AccessPanel" targetRef="Task_FillFilters" />
    <bpmn:sequenceFlow id="Flow_ToSelection" sourceRef="Task_FillFilters" targetRef="Gateway_SelectAction" />
    <bpmn:sequenceFlow id="Flow_ToStats" name="Consultar Totales" sourceRef="Gateway_SelectAction" targetRef="Task_QueryDB" />
    <bpmn:sequenceFlow id="Flow_ToPDF" name="Exportar Reporte" sourceRef="Gateway_SelectAction" targetRef="Task_QueryDB" />
    <bpmn:sequenceFlow id="Flow_ToDB" sourceRef="Task_QueryDB" targetRef="Task_DBSelect" />
    <bpmn:sequenceFlow id="Flow_FromDB" sourceRef="Task_DBSelect" targetRef="Gateway_QueryCheck" />
    <bpmn:sequenceFlow id="Flow_QueryOk" name="Sí" sourceRef="Gateway_QueryCheck" targetRef="Gateway_ResponseSplit" />
    <bpmn:sequenceFlow id="Flow_QueryErr" name="No" sourceRef="Gateway_QueryCheck" targetRef="Task_RenderError" />
    <bpmn:sequenceFlow id="Flow_RespStats" name="JSON de Totales" sourceRef="Gateway_ResponseSplit" targetRef="Task_RenderStats" />
    <bpmn:sequenceFlow id="Flow_RespPDF" name="Flujo PDF" sourceRef="Gateway_ResponseSplit" targetRef="Task_CompilePDF" />
    <bpmn:sequenceFlow id="Flow_ToStream" sourceRef="Task_CompilePDF" targetRef="Task_StreamPDF" />
    <bpmn:sequenceFlow id="Flow_ToDownload" sourceRef="Task_StreamPDF" targetRef="Task_TriggerDownload" />
    <bpmn:sequenceFlow id="Flow_EndWeb" sourceRef="Task_RenderStats" targetRef="EndEvent_ShowWeb" />
    <bpmn:sequenceFlow id="Flow_EndPDF" sourceRef="Task_TriggerDownload" targetRef="EndEvent_DownloadPDF" />
    <bpmn:sequenceFlow id="Flow_EndErr" sourceRef="Task_RenderError" targetRef="EndEvent_FailReport" />
    <bpmn:task id="Task_QueryDB" name="Ejecutar Query de Sumarización (Sequelize)">
      <bpmn:incoming>Flow_ToStats</bpmn:incoming>
      <bpmn:incoming>Flow_ToPDF</bpmn:incoming>
      <bpmn:outgoing>Flow_ToDB</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_DownloadPDF" name="Reporte PDF Descargado">
      <bpmn:incoming>Flow_EndPDF</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_RenderError" name="Mostrar Alerta de Error en Pantalla">
      <bpmn:incoming>Flow_QueryErr</bpmn:incoming>
      <bpmn:outgoing>Flow_EndErr</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RenderStats" name="Renderizar Totales y Gráficos en Pantalla">
      <bpmn:incoming>Flow_RespStats</bpmn:incoming>
      <bpmn:outgoing>Flow_EndWeb</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_StreamPDF" name="Transmitir Bytes al HTTP Response (pipe res)">
      <bpmn:incoming>Flow_ToStream</bpmn:incoming>
      <bpmn:outgoing>Flow_ToDownload</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_CompilePDF" name="Generar y Dibujar PDF en Memoria (PDFKit)">
      <bpmn:incoming>Flow_RespPDF</bpmn:incoming>
      <bpmn:outgoing>Flow_ToStream</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_ResponseSplit" name="¿Tipo de Petición?">
      <bpmn:incoming>Flow_QueryOk</bpmn:incoming>
      <bpmn:outgoing>Flow_RespStats</bpmn:outgoing>
      <bpmn:outgoing>Flow_RespPDF</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_QueryCheck" name="¿Consulta Exitosa?">
      <bpmn:incoming>Flow_FromDB</bpmn:incoming>
      <bpmn:outgoing>Flow_QueryOk</bpmn:outgoing>
      <bpmn:outgoing>Flow_QueryErr</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_DBSelect" name="Calcular SUM de Ventas e Ingresos por Categoría">
      <bpmn:incoming>Flow_ToDB</bpmn:incoming>
      <bpmn:outgoing>Flow_FromDB</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutput_DB">
        <bpmn:targetRef>DataStore_Reporte</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:task id="Task_TriggerDownload" name="Iniciar Descarga del Archivo Binario (Navegador)">
      <bpmn:incoming>Flow_ToDownload</bpmn:incoming>
      <bpmn:outgoing>Flow_EndPDF</bpmn:outgoing>
    </bpmn:task>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Reporte">
    <bpmndi:BPMNPlane id="BPMNPlane_Reporte" bpmnElement="Collaboration_Reporte">
      <bpmndi:BPMNShape id="Participant_Reporte_di" bpmnElement="Participant_Reporte" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1320" height="660" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_DB_di" bpmnElement="Lane_DB" isHorizontal="true" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="190" y="580" width="1290" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Server_di" bpmnElement="Lane_Server" isHorizontal="true" bioc:stroke="#831311" bioc:fill="#ffcdd2" color:background-color="#ffcdd2" color:border-color="#831311">
        <dc:Bounds x="190" y="380" width="1290" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Web_di" bpmnElement="Lane_Web" isHorizontal="true" bioc:stroke="#5b176d" bioc:fill="#e1bee7" color:background-color="#e1bee7" color:border-color="#5b176d">
        <dc:Bounds x="190" y="240" width="1290" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_User_di" bpmnElement="Lane_User" isHorizontal="true" bioc:stroke="#263238" bioc:fill="#cfd8dc" color:background-color="#cfd8dc" color:border-color="#263238">
        <dc:Bounds x="190" y="80" width="1290" height="160" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_Reporte_di" bpmnElement="StartEvent_Reporte">
        <dc:Bounds x="242" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="220" y="185" width="81" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AccessPanel_di" bpmnElement="Task_AccessPanel">
        <dc:Bounds x="330" y="120" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_FillFilters_di" bpmnElement="Task_FillFilters">
        <dc:Bounds x="480" y="120" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SelectAction_di" bpmnElement="Gateway_SelectAction" isMarkerVisible="true">
        <dc:Bounds x="635" y="135" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="632" y="104" width="76" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataStore_Reporte_di" bpmnElement="DataStore_Reporte">
        <dc:Bounds x="455" y="635" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="444" y="695" width="73" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ShowWeb_di" bpmnElement="EndEvent_ShowWeb">
        <dc:Bounds x="912" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="894" y="104.5" width="71" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_FailReport_di" bpmnElement="EndEvent_FailReport">
        <dc:Bounds x="1080" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1068" y="185" width="60" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_QueryDB_di" bpmnElement="Task_QueryDB">
        <dc:Bounds x="520" y="410" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_DownloadPDF_di" bpmnElement="EndEvent_DownloadPDF">
        <dc:Bounds x="1282" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1267" y="104.5" width="65" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RenderError_di" bpmnElement="Task_RenderError">
        <dc:Bounds x="950" y="270" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RenderStats_di" bpmnElement="Task_RenderStats">
        <dc:Bounds x="790" y="270" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_StreamPDF_di" bpmnElement="Task_StreamPDF">
        <dc:Bounds x="1240" y="440" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CompilePDF_di" bpmnElement="Task_CompilePDF">
        <dc:Bounds x="1038" y="440" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ResponseSplit_di" bpmnElement="Gateway_ResponseSplit" isMarkerVisible="true">
        <dc:Bounds x="875" y="455" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="877" y="515" width="46" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_QueryCheck_di" bpmnElement="Gateway_QueryCheck" isMarkerVisible="true">
        <dc:Bounds x="775" y="455" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="739" y="506" width="51" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DBSelect_di" bpmnElement="Task_DBSelect">
        <dc:Bounds x="630" y="610" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_TriggerDownload_di" bpmnElement="Task_TriggerDownload">
        <dc:Bounds x="1240" y="260" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_di" bpmnElement="Flow_Start">
        <di:waypoint x="278" y="160" />
        <di:waypoint x="330" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToFilters_di" bpmnElement="Flow_ToFilters">
        <di:waypoint x="450" y="160" />
        <di:waypoint x="480" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToSelection_di" bpmnElement="Flow_ToSelection">
        <di:waypoint x="600" y="160" />
        <di:waypoint x="635" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToStats_di" bpmnElement="Flow_ToStats" bioc:stroke="#0d4372" color:border-color="#0d4372">
        <di:waypoint x="660" y="185" />
        <di:waypoint x="660" y="210" />
        <di:waypoint x="580" y="210" />
        <di:waypoint x="580" y="410" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="487" y="303" width="86" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToPDF_di" bpmnElement="Flow_ToPDF" bioc:stroke="#0d4372" color:border-color="#0d4372">
        <di:waypoint x="685" y="160" />
        <di:waypoint x="710" y="160" />
        <di:waypoint x="710" y="450" />
        <di:waypoint x="640" y="450" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="618" y="393" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToDB_di" bpmnElement="Flow_ToDB">
        <di:waypoint x="580" y="490" />
        <di:waypoint x="580" y="570" />
        <di:waypoint x="690" y="570" />
        <di:waypoint x="690" y="610" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_FromDB_di" bpmnElement="Flow_FromDB">
        <di:waypoint x="750" y="650" />
        <di:waypoint x="800" y="650" />
        <di:waypoint x="800" y="505" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_QueryOk_di" bpmnElement="Flow_QueryOk" bioc:stroke="#205022" color:border-color="#205022">
        <di:waypoint x="825" y="480" />
        <di:waypoint x="875" y="480" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="845" y="462" width="11" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_QueryErr_di" bpmnElement="Flow_QueryErr" bioc:stroke="#831311" color:border-color="#831311">
        <di:waypoint x="800" y="455" />
        <di:waypoint x="800" y="400" />
        <di:waypoint x="760" y="400" />
        <di:waypoint x="760" y="370" />
        <di:waypoint x="1000" y="370" />
        <di:waypoint x="1000" y="350" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="777" y="447" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_RespStats_di" bpmnElement="Flow_RespStats">
        <di:waypoint x="900" y="455" />
        <di:waypoint x="900" y="403" />
        <di:waypoint x="860" y="403" />
        <di:waypoint x="860" y="350" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="854" y="421" width="83" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_RespPDF_di" bpmnElement="Flow_RespPDF">
        <di:waypoint x="925" y="480" />
        <di:waypoint x="1038" y="480" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="947" y="462" width="49" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToStream_di" bpmnElement="Flow_ToStream">
        <di:waypoint x="1158" y="480" />
        <di:waypoint x="1240" y="480" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToDownload_di" bpmnElement="Flow_ToDownload">
        <di:waypoint x="1300" y="440" />
        <di:waypoint x="1300" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EndWeb_di" bpmnElement="Flow_EndWeb">
        <di:waypoint x="870" y="270" />
        <di:waypoint x="870" y="160" />
        <di:waypoint x="912" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EndPDF_di" bpmnElement="Flow_EndPDF">
        <di:waypoint x="1300" y="260" />
        <di:waypoint x="1300" y="178" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EndErr_di" bpmnElement="Flow_EndErr">
        <di:waypoint x="1030" y="270" />
        <di:waypoint x="1030" y="160" />
        <di:waypoint x="1080" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="DataOutput_DB_di" bpmnElement="DataOutput_DB">
        <di:waypoint x="630" y="653" />
        <di:waypoint x="505" y="659" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
