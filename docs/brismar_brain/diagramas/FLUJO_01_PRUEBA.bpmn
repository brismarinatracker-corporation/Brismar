<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0"
  xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0"
  id="Definitions_Prueba"
  targetNamespace="http://bpmn.io/schema/bpmn">

  <!--
    ╔══════════════════════════════════════════════════════════════════════╗
    ║  FLUJO_01_PRUEBA — Bucle acotado de login (máximo 5 intentos)       ║
    ║  PROPÓSITO: Archivo educativo. Demuestra el patrón de loop con      ║
    ║  límite de iteraciones. Tras 5 fallos → cuenta bloqueada.           ║
    ║                                                                      ║
    ║  CONDICIONES (conditionExpression en gateways):                     ║
    ║    Flow_ReintentoPermitido : ${intentos < 5}                        ║
    ║    Flow_LimiteSuperado     : ${intentos >= 5}                       ║
    ╚══════════════════════════════════════════════════════════════════════╝
  -->

  <bpmn:collaboration id="Colaboracion_Prueba">
    <bpmn:participant
      id="Participant_Prueba"
      name="PRUEBA — Bucle de Login con Máximo 5 Intentos"
      processRef="Process_Prueba" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Prueba"
    name="Proceso Prueba: Bucle Acotado de Autenticación"
    isExecutable="false">

    <bpmn:documentation>
      ARCHIVO DE PRUEBA — No es el flujo oficial de producción.
      Demuestra cómo modelar un bucle con límite de N iteraciones en BPMN.

      LÓGICA:
        1. El usuario ingresa correo + contraseña.
        2. Supabase valida las credenciales.
        3a. Si son CORRECTAS → se resetea el contador → accede al Dashboard.
        3b. Si son INCORRECTAS → se incrementa el contador.
           - Si contador menor a 5 → puede volver a intentarlo (loop).
           - Si contador igual a 5 → la cuenta se bloquea 30 minutos.

      CONDICIONES FORMALES:
        Flow_ReintentoPermitido : expresión ${intentos &lt; 5}
        Flow_LimiteSuperado     : expresión ${intentos >= 5}
    </bpmn:documentation>

    <!-- ═══════════════ LANE SET ═══════════════ -->
    <bpmn:laneSet id="LaneSet_Prueba">

      <bpmn:lane id="Lane_Usuario" name="👤  Personal de Bahía (Usuario)">
        <bpmn:flowNodeRef>StartEvent_AbreApp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_IngresarCredenciales</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Dashboard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Bloqueado</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_App" name="📱  Aplicación Móvil (Lógica de Negocio)">
        <bpmn:flowNodeRef>Gateway_CredCorrectas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_IncrementarContador</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_LimiteAlcanzado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ResetContador</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_BloquearCuenta</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>DataObjectReference_Contador</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Supabase" name="☁️  Servidor Central (Supabase)">
        <bpmn:flowNodeRef>Task_ValidarEnServidor</bpmn:flowNodeRef>
      </bpmn:lane>

    </bpmn:laneSet>

    <!-- ═══════════════ DATA OBJECT ═══════════════ -->
    <bpmn:dataObjectReference
      id="DataObjectReference_Contador"
      name="Contador de Intentos&#10;(valor: 0 → 5)"
      dataObjectRef="DataObject_Contador" />
    <bpmn:dataObject id="DataObject_Contador" />

    <!-- ═══════════════ EVENTOS ═══════════════ -->

    <bpmn:startEvent id="StartEvent_AbreApp" name="Usuario&#10;Abre la App">
      <bpmn:outgoing>Flow_InicioAIngreso</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:endEvent id="EndEvent_Dashboard" name="✅ Acceso Concedido&#10;(Dashboard Principal)">
      <bpmn:incoming>Flow_ResetADashboard</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Bloqueado" name="🔒 Cuenta Bloqueada&#10;(30 minutos)">
      <bpmn:incoming>Flow_BloqueoAFin</bpmn:incoming>
      <bpmn:errorEventDefinition id="ErrorDef_Bloqueo" />
    </bpmn:endEvent>

    <!-- ═══════════════ TAREAS ═══════════════ -->

    <bpmn:task id="Task_IngresarCredenciales"
      name="Ingresar Correo&#10;y Contraseña">
      <bpmn:incoming>Flow_InicioAIngreso</bpmn:incoming>
      <bpmn:incoming>Flow_ReintentoPermitido</bpmn:incoming>
      <bpmn:outgoing>Flow_IngresoAValidar</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_ValidarEnServidor"
      name="Validar Credenciales&#10;en Supabase&#10;(signInWithPassword)">
      <bpmn:incoming>Flow_IngresoAValidar</bpmn:incoming>
      <bpmn:outgoing>Flow_ValidarAGateway</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Task_IncrementarContador"
      name="Incrementar Contador&#10;intentos = intentos + 1">
      <bpmn:incoming>Flow_CredInvalidas</bpmn:incoming>
      <bpmn:outgoing>Flow_ContadorALimite</bpmn:outgoing>
      <bpmn:property id="Property_ContadorIn" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInput_LeerContador">
        <bpmn:sourceRef>DataObjectReference_Contador</bpmn:sourceRef>
        <bpmn:targetRef>Property_ContadorIn</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="DataOutput_EscribirContador">
        <bpmn:targetRef>DataObjectReference_Contador</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>

    <bpmn:task id="Task_ResetContador"
      name="Resetear Contador&#10;intentos = 0">
      <bpmn:incoming>Flow_CredCorrectas</bpmn:incoming>
      <bpmn:outgoing>Flow_ResetADashboard</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutput_ResetContador">
        <bpmn:targetRef>DataObjectReference_Contador</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>

    <bpmn:task id="Task_BloquearCuenta"
      name="Bloquear Cuenta&#10;(guardar timestamp de bloqueo&#10;en Bóveda Segura)">
      <bpmn:incoming>Flow_LimiteSuperado</bpmn:incoming>
      <bpmn:outgoing>Flow_BloqueoAFin</bpmn:outgoing>
    </bpmn:task>

    <!-- ═══════════════ GATEWAYS ═══════════════ -->

    <bpmn:exclusiveGateway id="Gateway_CredCorrectas"
      name="¿Credenciales&#10;Correctas?">
      <bpmn:incoming>Flow_ValidarAGateway</bpmn:incoming>
      <bpmn:outgoing>Flow_CredCorrectas</bpmn:outgoing>
      <bpmn:outgoing>Flow_CredInvalidas</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!--
      GATEWAY CLAVE DEL BUCLE
      Este gateway evalúa si se alcanzó el límite de 5 intentos.
      Las conditionExpression son evaluadas por el motor BPMN / simulador.
    -->
    <bpmn:exclusiveGateway id="Gateway_LimiteAlcanzado"
      name="¿Número de intentos&#10;llegó a 5?">
      <bpmn:incoming>Flow_ContadorALimite</bpmn:incoming>
      <bpmn:outgoing>Flow_ReintentoPermitido</bpmn:outgoing>
      <bpmn:outgoing>Flow_LimiteSuperado</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ═══════════════ SEQUENCE FLOWS ═══════════════ -->

    <bpmn:sequenceFlow id="Flow_InicioAIngreso"
      sourceRef="StartEvent_AbreApp"
      targetRef="Task_IngresarCredenciales" />

    <bpmn:sequenceFlow id="Flow_IngresoAValidar"
      sourceRef="Task_IngresarCredenciales"
      targetRef="Task_ValidarEnServidor" />

    <bpmn:sequenceFlow id="Flow_ValidarAGateway"
      sourceRef="Task_ValidarEnServidor"
      targetRef="Gateway_CredCorrectas" />

    <!-- ✓ Credenciales correctas → resetear contador -->
    <bpmn:sequenceFlow id="Flow_CredCorrectas"
      name="✓ Correcto"
      sourceRef="Gateway_CredCorrectas"
      targetRef="Task_ResetContador">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
        ${credencialesCorrectas == true}
      </bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <!-- ✗ Credenciales incorrectas → incrementar contador -->
    <bpmn:sequenceFlow id="Flow_CredInvalidas"
      name="✗ Incorrecto"
      sourceRef="Gateway_CredCorrectas"
      targetRef="Task_IncrementarContador">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
        ${credencialesCorrectas == false}
      </bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_ContadorALimite"
      sourceRef="Task_IncrementarContador"
      targetRef="Gateway_LimiteAlcanzado" />

    <!-- LOOP BACK: Aún puede reintentar (intentos < 5) -->
    <bpmn:sequenceFlow id="Flow_ReintentoPermitido"
      name="No — intentos &lt; 5&#10;↩ Puede reintentar"
      sourceRef="Gateway_LimiteAlcanzado"
      targetRef="Task_IngresarCredenciales">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
        ${intentos &lt; 5}
      </bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <!-- SALIDA DEL LOOP: Límite alcanzado → bloquear (intentos >= 5) -->
    <bpmn:sequenceFlow id="Flow_LimiteSuperado"
      name="Sí — intentos = 5&#10;🔒 Bloquear cuenta"
      sourceRef="Gateway_LimiteAlcanzado"
      targetRef="Task_BloquearCuenta">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">
        ${intentos &gt;= 5}
      </bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_ResetADashboard"
      sourceRef="Task_ResetContador"
      targetRef="EndEvent_Dashboard" />

    <bpmn:sequenceFlow id="Flow_BloqueoAFin"
      sourceRef="Task_BloquearCuenta"
      targetRef="EndEvent_Bloqueado" />

  </bpmn:process>

  <!-- ══════════════════════════════════════════════════════════════════
       DIAGRAMA VISUAL — Layout espacioso y ordenado
       Dimensiones del participante: 2800 x 800
       Lane Usuario  : y=80,  h=240
       Lane App      : y=320, h=320
       Lane Supabase : y=640, h=200
       ══════════════════════════════════════════════════════════════════ -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_Prueba">
    <bpmndi:BPMNPlane id="BPMNPlane_Prueba" bpmnElement="Colaboracion_Prueba">

      <!-- ── PARTICIPANTE ── -->
      <bpmndi:BPMNShape id="Participant_Prueba_di"
        bpmnElement="Participant_Prueba"
        isHorizontal="true">
        <dc:Bounds x="80" y="80" width="2780" height="760" />
      </bpmndi:BPMNShape>

      <!-- ── LANES ── -->
      <bpmndi:BPMNShape id="Lane_Usuario_di"
        bpmnElement="Lane_Usuario"
        isHorizontal="true"
        bioc:stroke="#0d4372" bioc:fill="#bbdefb"
        color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="110" y="80" width="2750" height="240" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Lane_App_di"
        bpmnElement="Lane_App"
        isHorizontal="true"
        bioc:stroke="#5b176d" bioc:fill="#e1bee7"
        color:background-color="#e1bee7" color:border-color="#5b176d">
        <dc:Bounds x="110" y="320" width="2750" height="320" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Lane_Supabase_di"
        bpmnElement="Lane_Supabase"
        isHorizontal="true"
        bioc:stroke="#831311" bioc:fill="#ffcdd2"
        color:background-color="#ffcdd2" color:border-color="#831311">
        <dc:Bounds x="110" y="640" width="2750" height="200" />
      </bpmndi:BPMNShape>

      <!-- ════════════════════════════════════
           NODOS — Lane Usuario (y: 80–320)
           Centro vertical: y=200
           ════════════════════════════════════ -->

      <!-- StartEvent (x=200) -->
      <bpmndi:BPMNShape id="StartEvent_AbreApp_di"
        bpmnElement="StartEvent_AbreApp">
        <dc:Bounds x="212" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="195" y="225" width="72" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task: Ingresar Credenciales (x=320) -->
      <bpmndi:BPMNShape id="Task_IngresarCredenciales_di"
        bpmnElement="Task_IngresarCredenciales"
        bioc:stroke="#0d4372" bioc:fill="#bbdefb"
        color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="330" y="160" width="180" height="80" />
      </bpmndi:BPMNShape>

      <!-- EndEvent Dashboard (x=2500) -->
      <bpmndi:BPMNShape id="EndEvent_Dashboard_di"
        bpmnElement="EndEvent_Dashboard">
        <dc:Bounds x="2612" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2580" y="225" width="102" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- EndEvent Bloqueado (x=2500, arriba) -->
      <bpmndi:BPMNShape id="EndEvent_Bloqueado_di"
        bpmnElement="EndEvent_Bloqueado"
        bioc:stroke="#831311" bioc:fill="#ffcdd2"
        color:background-color="#ffcdd2" color:border-color="#831311">
        <dc:Bounds x="2612" y="112" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2580" y="82" width="100" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ════════════════════════════════════
           NODOS — Lane App (y: 320–640)
           Centro vertical: y=480
           ════════════════════════════════════ -->

      <!-- Gateway: ¿Credenciales Correctas? (x=800) -->
      <bpmndi:BPMNShape id="Gateway_CredCorrectas_di"
        bpmnElement="Gateway_CredCorrectas"
        isMarkerVisible="true"
        bioc:stroke="#5b176d" bioc:fill="#e1bee7"
        color:background-color="#e1bee7" color:border-color="#5b176d">
        <dc:Bounds x="835" y="455" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="740" y="468" width="88" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task: Incrementar Contador (x=1100) -->
      <bpmndi:BPMNShape id="Task_IncrementarContador_di"
        bpmnElement="Task_IncrementarContador"
        bioc:stroke="#6b3a00" bioc:fill="#ffe0b2"
        color:background-color="#ffe0b2" color:border-color="#6b3a00">
        <dc:Bounds x="1050" y="440" width="200" height="80" />
      </bpmndi:BPMNShape>

      <!-- DataObject: Contador (x=1200, debajo de la tarea) -->
      <bpmndi:BPMNShape id="DataObjectReference_Contador_di"
        bpmnElement="DataObjectReference_Contador"
        isHorizontal="false">
        <dc:Bounds x="1137" y="570" width="36" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1100" y="626" width="112" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Gateway: ¿Límite Alcanzado? (x=1450) -->
      <bpmndi:BPMNShape id="Gateway_LimiteAlcanzado_di"
        bpmnElement="Gateway_LimiteAlcanzado"
        isMarkerVisible="true"
        bioc:stroke="#6b3a00" bioc:fill="#ffe0b2"
        color:background-color="#ffe0b2" color:border-color="#6b3a00">
        <dc:Bounds x="1475" y="455" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1380" y="418" width="120" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task: Bloquear Cuenta (x=1750) -->
      <bpmndi:BPMNShape id="Task_BloquearCuenta_di"
        bpmnElement="Task_BloquearCuenta"
        bioc:stroke="#831311" bioc:fill="#ffcdd2"
        color:background-color="#ffcdd2" color:border-color="#831311">
        <dc:Bounds x="1750" y="345" width="200" height="100" />
      </bpmndi:BPMNShape>

      <!-- Task: Reset Contador (x=2100) -->
      <bpmndi:BPMNShape id="Task_ResetContador_di"
        bpmnElement="Task_ResetContador"
        bioc:stroke="#1b5e20" bioc:fill="#c8e6c9"
        color:background-color="#c8e6c9" color:border-color="#1b5e20">
        <dc:Bounds x="2100" y="440" width="200" height="80" />
      </bpmndi:BPMNShape>

      <!-- ════════════════════════════════════
           NODOS — Lane Supabase (y: 640–840)
           Centro vertical: y=740
           ════════════════════════════════════ -->

      <!-- Task: Validar en Servidor (x=600) -->
      <bpmndi:BPMNShape id="Task_ValidarEnServidor_di"
        bpmnElement="Task_ValidarEnServidor"
        bioc:stroke="#831311" bioc:fill="#ffcdd2"
        color:background-color="#ffcdd2" color:border-color="#831311">
        <dc:Bounds x="560" y="700" width="220" height="80" />
      </bpmndi:BPMNShape>

      <!-- ════════════════════════════════════
           FLECHAS (Sequence Flows)
           ════════════════════════════════════ -->

      <!-- Inicio → Ingresar Credenciales -->
      <bpmndi:BPMNEdge id="Flow_InicioAIngreso_di" bpmnElement="Flow_InicioAIngreso">
        <di:waypoint x="248" y="200" />
        <di:waypoint x="330" y="200" />
      </bpmndi:BPMNEdge>

      <!-- Ingresar → Validar en Supabase (baja al lane Supabase) -->
      <bpmndi:BPMNEdge id="Flow_IngresoAValidar_di" bpmnElement="Flow_IngresoAValidar">
        <di:waypoint x="510" y="200" />
        <di:waypoint x="670" y="200" />
        <di:waypoint x="670" y="700" />
      </bpmndi:BPMNEdge>

      <!-- Validar → Gateway CredCorrectas (sube al lane App) -->
      <bpmndi:BPMNEdge id="Flow_ValidarAGateway_di" bpmnElement="Flow_ValidarAGateway">
        <di:waypoint x="780" y="740" />
        <di:waypoint x="860" y="740" />
        <di:waypoint x="860" y="505" />
      </bpmndi:BPMNEdge>

      <!-- Gateway → Correcto → Reset Contador (camino largo a la derecha) -->
      <bpmndi:BPMNEdge id="Flow_CredCorrectas_di" bpmnElement="Flow_CredCorrectas">
        <di:waypoint x="885" y="480" />
        <di:waypoint x="2100" y="480" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1440" y="455" width="65" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Gateway → Incorrecto → Incrementar Contador (hacia la derecha y abajo) -->
      <bpmndi:BPMNEdge id="Flow_CredInvalidas_di" bpmnElement="Flow_CredInvalidas">
        <di:waypoint x="860" y="505" />
        <di:waypoint x="860" y="590" />
        <di:waypoint x="1050" y="590" />
        <di:waypoint x="1050" y="480" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="898" y="568" width="78" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Incrementar Contador → Gateway Límite -->
      <bpmndi:BPMNEdge id="Flow_ContadorALimite_di" bpmnElement="Flow_ContadorALimite">
        <di:waypoint x="1250" y="480" />
        <di:waypoint x="1475" y="480" />
      </bpmndi:BPMNEdge>

      <!--
        FLECHA DEL LOOP (la más importante del diagrama)
        Gateway Límite → regresa a Task Ingresar Credenciales
        Condición: ${intentos < 5}
        La flecha sube, pasa por encima del lane y regresa al inicio del loop.
      -->
      <bpmndi:BPMNEdge id="Flow_ReintentoPermitido_di" bpmnElement="Flow_ReintentoPermitido">
        <di:waypoint x="1500" y="455" />
        <di:waypoint x="1500" y="290" />
        <di:waypoint x="420" y="290" />
        <di:waypoint x="420" y="240" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="850" y="263" width="130" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!--
        FLECHA DE SALIDA DEL LOOP
        Gateway Límite → Bloquear Cuenta
        Condición: ${intentos >= 5}
      -->
      <bpmndi:BPMNEdge id="Flow_LimiteSuperado_di" bpmnElement="Flow_LimiteSuperado">
        <di:waypoint x="1525" y="480" />
        <di:waypoint x="1620" y="480" />
        <di:waypoint x="1620" y="395" />
        <di:waypoint x="1750" y="395" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1614" y="415" width="118" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Reset → EndEvent Dashboard (sube al lane usuario) -->
      <bpmndi:BPMNEdge id="Flow_ResetADashboard_di" bpmnElement="Flow_ResetADashboard">
        <di:waypoint x="2300" y="480" />
        <di:waypoint x="2630" y="480" />
        <di:waypoint x="2630" y="218" />
      </bpmndi:BPMNEdge>

      <!-- Bloquear → EndEvent Bloqueado (sube al lane usuario) -->
      <bpmndi:BPMNEdge id="Flow_BloqueoAFin_di" bpmnElement="Flow_BloqueoAFin">
        <di:waypoint x="1950" y="395" />
        <di:waypoint x="2650" y="395" />
        <di:waypoint x="2650" y="148" />
      </bpmndi:BPMNEdge>

      <!-- DataAssociation: Leer contador -->
      <bpmndi:BPMNEdge id="DataInput_LeerContador_di" bpmnElement="DataInput_LeerContador">
        <di:waypoint x="1155" y="570" />
        <di:waypoint x="1155" y="520" />
      </bpmndi:BPMNEdge>

      <!-- DataAssociation: Escribir contador -->
      <bpmndi:BPMNEdge id="DataOutput_EscribirContador_di" bpmnElement="DataOutput_EscribirContador">
        <di:waypoint x="1175" y="520" />
        <di:waypoint x="1175" y="570" />
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
