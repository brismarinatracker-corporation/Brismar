<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_Sync" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_Sync">
    <bpmn:participant id="Participant_Sync" name="Sincronización Automática en Segundo Plano (Offline-First)" processRef="Process_Sync" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Sync" name="Proceso de Sincronización de Fondo" isExecutable="false">
    <bpmn:documentation>Este proceso describe la conciliación asíncrona de las capturas guardadas offline. Es despertado automáticamente al detectar red o de forma manual por el usuario mediante pull-to-refresh, subiendo los lotes acumulados a Supabase e impactando al Dashboard Web.</bpmn:documentation>
    <bpmn:laneSet id="LaneSet_Sync">
      <bpmn:lane id="Lane_User" name="Personal de Bahía (Usuario)">
        <bpmn:flowNodeRef>StartEvent_Manual</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RefreshUI</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_ManualDone</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_App" name="Aplicación Móvil (SQLite y Riverpod)">
        <bpmn:flowNodeRef>DataStore_LocalSQLite</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_QueryLocalUnsynced</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_HasPending</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Silent</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SendBatch</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReturnError</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UpdateSQLiteSynced</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SyncSuccess</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReloadUI</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>StartEvent_Auto</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_RetryScheduled</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ScheduleRetry</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Server" name="Servidor Central (Supabase / Nube)">
        <bpmn:flowNodeRef>Gateway_DBSaved</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_NotifyRealtime</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReceiveUpsert</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Web" name="Dashboard Web (Tierra / Bahía)">
        <bpmn:flowNodeRef>Task_WebReload</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_WebReloaded</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_Manual" name="Pull to Refresh en Historial">
      <bpmn:outgoing>Flow_ManualStart</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="Flow_ManualStart" sourceRef="StartEvent_Manual" targetRef="Task_QueryLocalUnsynced" />
    <bpmn:sequenceFlow id="Flow_AutoStart" sourceRef="StartEvent_Auto" targetRef="Task_QueryLocalUnsynced" />
    <bpmn:sequenceFlow id="Flow_ToPendingCheck" sourceRef="Task_QueryLocalUnsynced" targetRef="Gateway_HasPending" />
    <bpmn:sequenceFlow id="Flow_HasNoPending" name="No" sourceRef="Gateway_HasPending" targetRef="EndEvent_Silent" />
    <bpmn:sequenceFlow id="Flow_HasPendingRecords" name="Sí" sourceRef="Gateway_HasPending" targetRef="Task_SendBatch" />
    <bpmn:sequenceFlow id="Flow_ToSupabase" sourceRef="Task_SendBatch" targetRef="Task_ReceiveUpsert" />
    <bpmn:sequenceFlow id="Flow_ToDBSaveCheck" sourceRef="Task_ReceiveUpsert" targetRef="Gateway_DBSaved" />
    <bpmn:sequenceFlow id="Flow_DBSavedOk" name="Sí" sourceRef="Gateway_DBSaved" targetRef="Task_NotifyRealtime" />
    <bpmn:sequenceFlow id="Flow_DBSavedFail" name="No" sourceRef="Gateway_DBSaved" targetRef="Task_ReturnError" />
    <bpmn:sequenceFlow id="Flow_FromSupabaseFail" sourceRef="Task_ReturnError" targetRef="Gateway_SyncSuccess" />
    <bpmn:sequenceFlow id="Flow_SyncOk" name="Sí" sourceRef="Gateway_SyncSuccess" targetRef="Task_UpdateSQLiteSynced" />
    <bpmn:sequenceFlow id="Flow_SyncFail" name="No" sourceRef="Gateway_SyncSuccess" targetRef="Task_ScheduleRetry" />
    <bpmn:sequenceFlow id="Flow_ToReload" sourceRef="Task_UpdateSQLiteSynced" targetRef="Task_ReloadUI" />
    <bpmn:sequenceFlow id="Flow_ToRefreshUser" sourceRef="Task_ReloadUI" targetRef="Task_RefreshUI" />
    <bpmn:sequenceFlow id="Flow_EndManual" sourceRef="Task_RefreshUI" targetRef="EndEvent_ManualDone" />
    <bpmn:sequenceFlow id="Flow_EndRetry" sourceRef="Task_ScheduleRetry" targetRef="EndEvent_RetryScheduled" />
    <bpmn:sequenceFlow id="Flow_ToWebRealtime" sourceRef="Task_NotifyRealtime" targetRef="Task_WebReload" />
    <bpmn:sequenceFlow id="Flow_EndWeb" sourceRef="Task_WebReload" targetRef="EndEvent_WebReloaded" />
    <bpmn:exclusiveGateway id="Gateway_DBSaved" name="¿Postgres Guardó Correctamente?">
      <bpmn:incoming>Flow_ToDBSaveCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_DBSavedOk</bpmn:outgoing>
      <bpmn:outgoing>Flow_DBSavedFail</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_QueryLocalUnsynced" name="Consultar SQLite (sincronizado = 0)">
      <bpmn:incoming>Flow_ManualStart</bpmn:incoming>
      <bpmn:incoming>Flow_AutoStart</bpmn:incoming>
      <bpmn:outgoing>Flow_ToPendingCheck</bpmn:outgoing>
      <bpmn:property id="Property_LocalSQLite" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInput_SQLite">
        <bpmn:sourceRef>DataStore_LocalSQLite</bpmn:sourceRef>
        <bpmn:targetRef>Property_LocalSQLite</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:task>
    <bpmn:dataStoreReference id="DataStore_LocalSQLite" name="SQLite local (App)" />
    <bpmn:exclusiveGateway id="Gateway_HasPending" name="¿Hay registros pendientes?">
      <bpmn:incoming>Flow_ToPendingCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_HasNoPending</bpmn:outgoing>
      <bpmn:outgoing>Flow_HasPendingRecords</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_Silent" name="Fin Silencioso (App en Reposo)">
      <bpmn:incoming>Flow_HasNoPending</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_SendBatch" name="Enviar Lote en Formato JSON (Bulk)">
      <bpmn:incoming>Flow_HasPendingRecords</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSupabase</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ReturnError" name="Retornar Mensaje de Fallo">
      <bpmn:incoming>Flow_DBSavedFail</bpmn:incoming>
      <bpmn:outgoing>Flow_FromSupabaseFail</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_UpdateSQLiteSynced" name="Actualizar SQLite local (sincronizado = 1)">
      <bpmn:incoming>Flow_SyncOk</bpmn:incoming>
      <bpmn:outgoing>Flow_ToReload</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutput_SQLite">
        <bpmn:targetRef>DataStore_LocalSQLite</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_SyncSuccess" name="¿Subida Exitosa?">
      <bpmn:incoming>Flow_FromSupabaseFail</bpmn:incoming>
      <bpmn:outgoing>Flow_SyncOk</bpmn:outgoing>
      <bpmn:outgoing>Flow_SyncFail</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_ReloadUI" name="Recargar Lista en UI de la App">
      <bpmn:incoming>Flow_ToReload</bpmn:incoming>
      <bpmn:outgoing>Flow_ToRefreshUser</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_NotifyRealtime" name="Transmitir Señal en Canal Realtime">
      <bpmn:incoming>Flow_DBSavedOk</bpmn:incoming>
      <bpmn:outgoing>Flow_ToWebRealtime</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_WebReload" name="Actualizar Dashboard de Oficina Instantáneamente">
      <bpmn:incoming>Flow_ToWebRealtime</bpmn:incoming>
      <bpmn:outgoing>Flow_EndWeb</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_WebReloaded" name="Datos de Oficina Conciliados">
      <bpmn:incoming>Flow_EndWeb</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_RefreshUI" name="Ver Registros con Check Verde en UI">
      <bpmn:incoming>Flow_ToRefreshUser</bpmn:incoming>
      <bpmn:outgoing>Flow_EndManual</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_ManualDone" name="Historial Sincronizado">
      <bpmn:incoming>Flow_EndManual</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_ReceiveUpsert" name="Procesar Upsert Masivo y Validar RLS">
      <bpmn:incoming>Flow_ToSupabase</bpmn:incoming>
      <bpmn:outgoing>Flow_ToDBSaveCheck</bpmn:outgoing>
    </bpmn:task>
    <bpmn:startEvent id="StartEvent_Auto" name=" connectivity_plus Detecta Internet">
      <bpmn:outgoing>Flow_AutoStart</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_RetryScheduled" name="Reintento Programado">
      <bpmn:incoming>Flow_EndRetry</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_ScheduleRetry" name="Programar Reintento de Sincronización">
      <bpmn:incoming>Flow_SyncFail</bpmn:incoming>
      <bpmn:outgoing>Flow_EndRetry</bpmn:outgoing>
    </bpmn:task>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Sync">
    <bpmndi:BPMNPlane id="BPMNPlane_Sync" bpmnElement="Collaboration_Sync">
      <bpmndi:BPMNShape id="Participant_Sync_di" bpmnElement="Participant_Sync" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1240" height="680" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Web_di" bpmnElement="Lane_Web" isHorizontal="true" bioc:stroke="#1b5e20" bioc:fill="#c8e6c9" color:background-color="#c8e6c9" color:border-color="#1b5e20">
        <dc:Bounds x="190" y="610" width="1210" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Server_di" bpmnElement="Lane_Server" isHorizontal="true" bioc:stroke="#831311" bioc:fill="#ffcdd2" color:background-color="#ffcdd2" color:border-color="#831311">
        <dc:Bounds x="190" y="460" width="1210" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_App_di" bpmnElement="Lane_App" isHorizontal="true" bioc:stroke="#5b176d" bioc:fill="#e1bee7" color:background-color="#e1bee7" color:border-color="#5b176d">
        <dc:Bounds x="190" y="220" width="1210" height="240" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_User_di" bpmnElement="Lane_User" isHorizontal="true" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="190" y="80" width="1210" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_Manual_di" bpmnElement="StartEvent_Manual">
        <dc:Bounds x="232" y="132" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="256" y="116" width="88" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_DBSaved_di" bpmnElement="Gateway_DBSaved" isMarkerVisible="true">
        <dc:Bounds x="750" y="475" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="731" y="535" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_QueryLocalUnsynced_di" bpmnElement="Task_QueryLocalUnsynced">
        <dc:Bounds x="310" y="250" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataStore_LocalSQLite_di" bpmnElement="DataStore_LocalSQLite">
        <dc:Bounds x="345" y="355" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="255" y="403" width="90" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_HasPending_di" bpmnElement="Gateway_HasPending" isMarkerVisible="true">
        <dc:Bounds x="480" y="255" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="464" y="226" width="72" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Silent_di" bpmnElement="EndEvent_Silent">
        <dc:Bounds x="487" y="342" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="463" y="385" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SendBatch_di" bpmnElement="Task_SendBatch">
        <dc:Bounds x="580" y="240" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReturnError_di" bpmnElement="Task_ReturnError">
        <dc:Bounds x="715" y="330" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_UpdateSQLiteSynced_di" bpmnElement="Task_UpdateSQLiteSynced">
        <dc:Bounds x="1010" y="250" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_SyncSuccess_di" bpmnElement="Gateway_SyncSuccess" isMarkerVisible="true">
        <dc:Bounds x="845" y="245" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="839" y="225" width="87" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReloadUI_di" bpmnElement="Task_ReloadUI">
        <dc:Bounds x="1220" y="250" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyRealtime_di" bpmnElement="Task_NotifyRealtime">
        <dc:Bounds x="880" y="470" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_WebReload_di" bpmnElement="Task_WebReload">
        <dc:Bounds x="1050" y="650" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_WebReloaded_di" bpmnElement="EndEvent_WebReloaded" bioc:stroke="#205022" bioc:fill="#c8e6c9" color:background-color="#c8e6c9" color:border-color="#205022">
        <dc:Bounds x="1292" y="672" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1269" y="715" width="82" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RefreshUI_di" bpmnElement="Task_RefreshUI">
        <dc:Bounds x="1160" y="100" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_ManualDone_di" bpmnElement="EndEvent_ManualDone" bioc:stroke="#205022" bioc:fill="#c8e6c9" color:background-color="#c8e6c9" color:border-color="#205022">
        <dc:Bounds x="1342" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1329" y="165" width="64" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReceiveUpsert_di" bpmnElement="Task_ReceiveUpsert">
        <dc:Bounds x="560" y="470" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_Auto_di" bpmnElement="StartEvent_Auto">
        <dc:Bounds x="232" y="272" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="217" y="309" width="85" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_RetryScheduled_di" bpmnElement="EndEvent_RetryScheduled">
        <dc:Bounds x="1322" y="372" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1310" y="415" width="61" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ScheduleRetry_di" bpmnElement="Task_ScheduleRetry">
        <dc:Bounds x="980" y="350" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_ManualStart_di" bpmnElement="Flow_ManualStart">
        <di:waypoint x="268" y="150" />
        <di:waypoint x="370" y="150" />
        <di:waypoint x="370" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_AutoStart_di" bpmnElement="Flow_AutoStart">
        <di:waypoint x="268" y="290" />
        <di:waypoint x="310" y="290" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToPendingCheck_di" bpmnElement="Flow_ToPendingCheck">
        <di:waypoint x="430" y="280" />
        <di:waypoint x="480" y="280" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_HasNoPending_di" bpmnElement="Flow_HasNoPending" bioc:stroke="#831311" color:border-color="#831311">
        <di:waypoint x="505" y="305" />
        <di:waypoint x="505" y="342" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="512" y="316" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_HasPendingRecords_di" bpmnElement="Flow_HasPendingRecords" bioc:stroke="#205022" color:border-color="#205022">
        <di:waypoint x="530" y="280" />
        <di:waypoint x="580" y="280" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="552" y="262" width="11" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToSupabase_di" bpmnElement="Flow_ToSupabase">
        <di:waypoint x="640" y="320" />
        <di:waypoint x="640" y="410" />
        <di:waypoint x="620" y="410" />
        <di:waypoint x="620" y="470" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToDBSaveCheck_di" bpmnElement="Flow_ToDBSaveCheck">
        <di:waypoint x="680" y="500" />
        <di:waypoint x="750" y="500" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_DBSavedOk_di" bpmnElement="Flow_DBSavedOk" bioc:stroke="#205022" color:border-color="#205022">
        <di:waypoint x="800" y="500" />
        <di:waypoint x="880" y="500" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="836" y="482" width="11" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_DBSavedFail_di" bpmnElement="Flow_DBSavedFail" bioc:stroke="#831311" color:border-color="#831311">
        <di:waypoint x="775" y="475" />
        <di:waypoint x="775" y="410" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="782" y="433" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_FromSupabaseFail_di" bpmnElement="Flow_FromSupabaseFail">
        <di:waypoint x="775" y="330" />
        <di:waypoint x="775" y="270" />
        <di:waypoint x="845" y="270" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SyncOk_di" bpmnElement="Flow_SyncOk" bioc:stroke="#205022" color:border-color="#205022">
        <di:waypoint x="895" y="270" />
        <di:waypoint x="953" y="270" />
        <di:waypoint x="953" y="290" />
        <di:waypoint x="1010" y="290" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="919" y="252" width="11" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_SyncFail_di" bpmnElement="Flow_SyncFail" bioc:stroke="#831311" color:border-color="#831311">
        <di:waypoint x="870" y="295" />
        <di:waypoint x="870" y="390" />
        <di:waypoint x="980" y="390" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="870" y="377" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToReload_di" bpmnElement="Flow_ToReload">
        <di:waypoint x="1130" y="290" />
        <di:waypoint x="1220" y="290" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToRefreshUser_di" bpmnElement="Flow_ToRefreshUser">
        <di:waypoint x="1280" y="250" />
        <di:waypoint x="1280" y="215" />
        <di:waypoint x="1250" y="215" />
        <di:waypoint x="1250" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EndManual_di" bpmnElement="Flow_EndManual">
        <di:waypoint x="1280" y="140" />
        <di:waypoint x="1342" y="140" />
      </bpmndi:BPMNEdge>
