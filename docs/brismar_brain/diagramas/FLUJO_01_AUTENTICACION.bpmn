<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Flujo1">
    <bpmn:participant id="Participant_1" name="Autenticación Híbrida: Login Inicial vs Acceso Diario Rápido" processRef="Process_1" />
  </bpmn:collaboration>
  <bpmn:process id="Process_1" name="Proceso de Autenticación Híbrida (Online/Offline)" isExecutable="false">
    <bpmn:documentation>Este proceso describe el inicio de sesión del Personal de Bahía en la aplicación de Brismar. Gestiona la bifurcación entre un inicio de sesión completo (correo y contraseña, obligatorio al inicio) y el acceso simplificado diario (PIN obligatorio y huella digital opcional) controlado por un periodo de gracia de 12 horas.</bpmn:documentation>
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_Server" name="Servidor Central (Supabase)">
        <bpmn:flowNodeRef>DataStoreReference_Supabase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SupabaseAuth</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_App" name="Aplicación Móvil (Lógica &#38; Bóveda Segura)">
        <bpmn:flowNodeRef>DataStoreReference_SecureStorage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_HasSession</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_GracePeriod</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SaveSession</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OfflineAuth</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_QuickAccessType</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ClearSession</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_OfflineHashCheck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_NetworkCheck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_OnlineAuth</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_OnlineAuthCheck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_UpdateTimestamp</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_User" name="Personal de Bahía (Usuario)">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SetupPIN</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SetupBiometrics</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ProvideBiometrics</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_BiometricCheck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Dashboard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FullLoginInput</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_InputPIN</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PINCheck</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_FailOfflineNoCache</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:exclusiveGateway id="Gateway_HasSession" name="¿Existe Token Local?">
      <bpmn:incoming>Flow_Start</bpmn:incoming>
      <bpmn:outgoing>Flow_NoSession</bpmn:outgoing>
      <bpmn:outgoing>Flow_HasSession</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_GracePeriod" name="¿Última verificación hace &#60; 12 horas?">
      <bpmn:incoming>Flow_HasSession</bpmn:incoming>
      <bpmn:outgoing>Flow_GraceYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_GraceNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:dataStoreReference id="DataStoreReference_SecureStorage" name="Bóveda Segura SQLITE3 (Secure Storage)" />
    <bpmn:sequenceFlow id="Flow_PINSuccess" name="Correcto" sourceRef="Gateway_PINCheck" targetRef="Task_UpdateTimestamp" />
    <bpmn:sequenceFlow id="Flow_PINForgot" name="Olvidé PIN" sourceRef="Gateway_PINCheck" targetRef="Task_ClearSession" />
    <bpmn:sequenceFlow id="Flow_Start" sourceRef="StartEvent_1" targetRef="Gateway_HasSession" />
    <bpmn:sequenceFlow id="Flow_NoSession" name="No" sourceRef="Gateway_HasSession" targetRef="Task_FullLoginInput" />
    <bpmn:sequenceFlow id="Flow_OnlineFailLoop" name="Incorrecto" sourceRef="Gateway_OnlineAuthCheck" targetRef="Task_FullLoginInput" />
    <bpmn:sequenceFlow id="Flow_OfflineFailLoop" name="Incorrecto" sourceRef="Gateway_OfflineHashCheck" targetRef="Task_FullLoginInput" />
    <bpmn:sequenceFlow id="Flow_FromClearSession" sourceRef="Task_ClearSession" targetRef="Task_FullLoginInput" />
    <bpmn:sequenceFlow id="Flow_ToNetworkCheck" sourceRef="Task_FullLoginInput" targetRef="Gateway_NetworkCheck" />
    <bpmn:sequenceFlow id="Flow_HasSession" name="Sí" sourceRef="Gateway_HasSession" targetRef="Gateway_GracePeriod" />
    <bpmn:sequenceFlow id="Flow_1i3243d" sourceRef="Gateway_OfflineHashCheck" targetRef="Gateway_OnlineAuthCheck" />
    <bpmn:sequenceFlow id="Flow_OnlineSuccess" name="Correcto" sourceRef="Gateway_OnlineAuthCheck" targetRef="Task_SetupPIN" />
    <bpmn:sequenceFlow id="Flow_OnlinePath" name="Sí" sourceRef="Gateway_NetworkCheck" targetRef="Task_OnlineAuth" />
    <bpmn:sequenceFlow id="Flow_ToSupabase" sourceRef="Task_OnlineAuth" targetRef="Task_SupabaseAuth" />
    <bpmn:sequenceFlow id="Flow_BiometricForgot" name="Olvidé PIN" sourceRef="Gateway_BiometricCheck" targetRef="Task_ClearSession" />
    <bpmn:sequenceFlow id="Flow_PrefPIN" name="PIN" sourceRef="Gateway_QuickAccessType" targetRef="Task_InputPIN" />
    <bpmn:sequenceFlow id="Flow_GraceYes" name="Sí" sourceRef="Gateway_GracePeriod" targetRef="EndEvent_Dashboard" />
    <bpmn:sequenceFlow id="Flow_GraceNo" name="No" sourceRef="Gateway_GracePeriod" targetRef="Gateway_QuickAccessType" />
    <bpmn:sequenceFlow id="Flow_PrefBiometrics" name="Huella" sourceRef="Gateway_QuickAccessType" targetRef="Task_ProvideBiometrics" />
    <bpmn:sequenceFlow id="Flow_OfflinePath" name="No" sourceRef="Gateway_NetworkCheck" targetRef="Task_OfflineAuth" />
    <bpmn:sequenceFlow id="Flow_FromSupabase" sourceRef="Task_SupabaseAuth" targetRef="Gateway_OnlineAuthCheck" />
    <bpmn:sequenceFlow id="Flow_ToDashboardDirect" sourceRef="Task_SaveSession" targetRef="EndEvent_Dashboard" />
    <bpmn:sequenceFlow id="Flow_ToDashboardAfterUpdate" sourceRef="Task_UpdateTimestamp" targetRef="EndEvent_Dashboard" />
    <bpmn:sequenceFlow id="Flow_OfflineNoCache" name="Sin Caché" sourceRef="Gateway_OfflineHashCheck" targetRef="EndEvent_FailOfflineNoCache" />
    <bpmn:sequenceFlow id="Flow_ToSaveSession" sourceRef="Task_SetupBiometrics" targetRef="Task_SaveSession" />
    <bpmn:sequenceFlow id="Flow_BiometricSuccess" name="Correcto" sourceRef="Gateway_BiometricCheck" targetRef="Task_UpdateTimestamp" />
    <bpmn:sequenceFlow id="Flow_OfflineSuccess" name="Correcto" sourceRef="Gateway_OfflineHashCheck" targetRef="Task_SetupPIN" />
    <bpmn:sequenceFlow id="Flow_ToOfflineHashCheck" sourceRef="Task_OfflineAuth" targetRef="Gateway_OfflineHashCheck" />
    <bpmn:startEvent id="StartEvent_1" name="Usuario Abre la App">
      <bpmn:outgoing>Flow_Start</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_SetupPIN" name="Configurar PIN (Obligatorio)">
      <bpmn:incoming>Flow_OnlineSuccess</bpmn:incoming>
      <bpmn:incoming>Flow_OfflineSuccess</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSetupBiometrics</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_SetupBiometrics" name="Configurar Huella (Opcional)">
      <bpmn:incoming>Flow_ToSetupBiometrics</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSaveSession</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ProvideBiometrics" name="Presentar Huella Digital">
      <bpmn:incoming>Flow_PrefBiometrics</bpmn:incoming>
      <bpmn:incoming>Flow_BiometricFailLoop</bpmn:incoming>
      <bpmn:outgoing>Flow_ToBiometricCheck</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_BiometricCheck" name="¿Huella Válida?">
      <bpmn:incoming>Flow_ToBiometricCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_BiometricSuccess</bpmn:outgoing>
      <bpmn:outgoing>Flow_BiometricFailLoop</bpmn:outgoing>
      <bpmn:outgoing>Flow_BiometricForgot</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_Dashboard" name="Acceso Concedido (Dashboard)">
      <bpmn:incoming>Flow_ToDashboardDirect</bpmn:incoming>
      <bpmn:incoming>Flow_GraceYes</bpmn:incoming>
      <bpmn:incoming>Flow_ToDashboardAfterUpdate</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_ToSetupBiometrics" sourceRef="Task_SetupPIN" targetRef="Task_SetupBiometrics" />
    <bpmn:sequenceFlow id="Flow_PINFailLoop" name="Incorrecto" sourceRef="Gateway_PINCheck" targetRef="Task_InputPIN" />
    <bpmn:sequenceFlow id="Flow_ToPINCheck" sourceRef="Task_InputPIN" targetRef="Gateway_PINCheck" />
    <bpmn:sequenceFlow id="Flow_BiometricFailLoop" name="Incorrecto" sourceRef="Gateway_BiometricCheck" targetRef="Task_ProvideBiometrics" />
    <bpmn:sequenceFlow id="Flow_ToBiometricCheck" sourceRef="Task_ProvideBiometrics" targetRef="Gateway_BiometricCheck" />
    <bpmn:task id="Task_FullLoginInput" name="Ingresar Correo y Contraseña">
      <bpmn:incoming>Flow_NoSession</bpmn:incoming>
      <bpmn:incoming>Flow_OnlineFailLoop</bpmn:incoming>
      <bpmn:incoming>Flow_OfflineFailLoop</bpmn:incoming>
      <bpmn:incoming>Flow_FromClearSession</bpmn:incoming>
      <bpmn:outgoing>Flow_ToNetworkCheck</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_SupabaseAuth" name="Validar Credenciales y Generar Token">
      <bpmn:incoming>Flow_ToSupabase</bpmn:incoming>
      <bpmn:outgoing>Flow_FromSupabase</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_Supabase">
        <bpmn:targetRef>DataStoreReference_Supabase</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:dataStoreReference id="DataStoreReference_Supabase" name="Base de Datos Central (Supabase)" />
    <bpmn:task id="Task_SaveSession" name="Persistir Token, Hash, PIN y Timestamp">
      <bpmn:incoming>Flow_ToSaveSession</bpmn:incoming>
      <bpmn:outgoing>Flow_ToDashboardDirect</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_SaveSession">
        <bpmn:targetRef>DataStoreReference_SecureStorage</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:task id="Task_OfflineAuth" name="Buscar Hash BCrypt Guardado">
      <bpmn:incoming>Flow_OfflinePath</bpmn:incoming>
      <bpmn:outgoing>Flow_ToOfflineHashCheck</bpmn:outgoing>
      <bpmn:property id="Property_OfflineAuth" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_OfflineRead">
        <bpmn:sourceRef>DataStoreReference_SecureStorage</bpmn:sourceRef>
        <bpmn:targetRef>Property_OfflineAuth</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_QuickAccessType" name="Preferencia Configurada">
      <bpmn:incoming>Flow_GraceNo</bpmn:incoming>
      <bpmn:outgoing>Flow_PrefPIN</bpmn:outgoing>
      <bpmn:outgoing>Flow_PrefBiometrics</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_InputPIN" name="Digitar PIN (Pantalla Numérica)">
      <bpmn:incoming>Flow_PrefPIN</bpmn:incoming>
      <bpmn:incoming>Flow_PINFailLoop</bpmn:incoming>
      <bpmn:outgoing>Flow_ToPINCheck</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ClearSession" name="Invalidad Token y PIN anterior en Bóveda">
      <bpmn:incoming>Flow_PINForgot</bpmn:incoming>
      <bpmn:incoming>Flow_BiometricForgot</bpmn:incoming>
      <bpmn:outgoing>Flow_FromClearSession</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_ClearSession">
        <bpmn:targetRef>DataStoreReference_SecureStorage</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_PINCheck" name="¿PIN Coincide?">
      <bpmn:incoming>Flow_ToPINCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_PINSuccess</bpmn:outgoing>
      <bpmn:outgoing>Flow_PINFailLoop</bpmn:outgoing>
      <bpmn:outgoing>Flow_PINForgot</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="Gateway_OfflineHashCheck" name="¿Coincide Contraseña Offline?">
      <bpmn:incoming>Flow_ToOfflineHashCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_OfflineSuccess</bpmn:outgoing>
      <bpmn:outgoing>Flow_OfflineFailLoop</bpmn:outgoing>
      <bpmn:outgoing>Flow_OfflineNoCache</bpmn:outgoing>
      <bpmn:outgoing>Flow_1i3243d</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_FailOfflineNoCache" name="Error: Requiere Inicio de Sesión Online">
      <bpmn:incoming>Flow_OfflineNoCache</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="Gateway_NetworkCheck" name="¿Tiene Internet?">
      <bpmn:incoming>Flow_ToNetworkCheck</bpmn:incoming>
      <bpmn:outgoing>Flow_OnlinePath</bpmn:outgoing>
      <bpmn:outgoing>Flow_OfflinePath</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_OnlineAuth" name="Solicitar Autenticación Online">
      <bpmn:incoming>Flow_OnlinePath</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSupabase</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_OnlineAuthCheck" name="¿Credenciales Correctas?">
      <bpmn:incoming>Flow_1i3243d</bpmn:incoming>
      <bpmn:incoming>Flow_FromSupabase</bpmn:incoming>
      <bpmn:outgoing>Flow_OnlineSuccess</bpmn:outgoing>
      <bpmn:outgoing>Flow_OnlineFailLoop</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_UpdateTimestamp" name="Actualizar Timestamp de Verificación en Bóveda">
      <bpmn:incoming>Flow_PINSuccess</bpmn:incoming>
      <bpmn:incoming>Flow_BiometricSuccess</bpmn:incoming>
      <bpmn:outgoing>Flow_ToDashboardAfterUpdate</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOutputAssociation_UpdateTimestamp">
        <bpmn:targetRef>DataStoreReference_SecureStorage</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:task>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Flujo1">
      <bpmndi:BPMNShape id="Participant_1_di" bpmnElement="Participant_1" isHorizontal="true">
        <dc:Bounds x="100" y="-210" width="2668" height="1510" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Server_di" bpmnElement="Lane_Server" isHorizontal="true" bioc:stroke="#831311" bioc:fill="#ffcdd2" color:background-color="#ffcdd2" color:border-color="#831311">
        <dc:Bounds x="130" y="950" width="2638" height="350" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_App_di" bpmnElement="Lane_App" isHorizontal="true" bioc:stroke="#5b176d" bioc:fill="#e1bee7" color:background-color="#e1bee7" color:border-color="#5b176d">
        <dc:Bounds x="130" y="240" width="2638" height="710" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_User_di" bpmnElement="Lane_User" isHorizontal="true" bioc:stroke="#0d4372" bioc:fill="#bbdefb" color:background-color="#bbdefb" color:border-color="#0d4372">
        <dc:Bounds x="130" y="-210" width="2638" height="450" />
      </bpmndi:BPMNShape>
