        <bpmndi:BPMNLabel>
          <dc:Bounds x="385" y="150" width="82" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataStoreReference_SecureStorage_di" bpmnElement="DataStoreReference_SecureStorage">
        <dc:Bounds x="2095" y="225" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2082" y="281" width="87" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1" isMarkerVisible="true">
        <dc:Bounds x="277" y="-393" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="257" y="-439" width="77" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_FullLoginInput_di" bpmnElement="Task_FullLoginInput" bioc:stroke="#5b176d" bioc:fill="#e1bee7" color:background-color="#e1bee7" color:border-color="#5b176d">
        <dc:Bounds x="435" y="-335" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SaveSession_di" bpmnElement="Task_SaveSession">
        <dc:Bounds x="2260" y="40" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_OfflineAuth_di" bpmnElement="Task_OfflineAuth">
        <dc:Bounds x="560" y="355" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_QuickAccessType_di" bpmnElement="Gateway_QuickAccessType" isMarkerVisible="true">
        <dc:Bounds x="835" y="-70" width="50" height="50" />
