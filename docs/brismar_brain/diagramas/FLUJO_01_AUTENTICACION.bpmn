        <dc:Bounds x="220" y="320" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="165" y="271" width="69" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_GracePeriod_di" bpmnElement="Gateway_GracePeriod" isMarkerVisible="true">
        <dc:Bounds x="275" y="510" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="335" y="515" width="82" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataStoreReference_SecureStorage_di" bpmnElement="DataStoreReference_SecureStorage">
        <dc:Bounds x="2045" y="590" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2032" y="646" width="87" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1" isMarkerVisible="true">
        <dc:Bounds x="227" y="-28" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="207" y="-74" width="77" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SetupPIN_di" bpmnElement="Task_SetupPIN">
        <dc:Bounds x="1795" y="-110" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SetupBiometrics_di" bpmnElement="Task_SetupBiometrics">
        <dc:Bounds x="2005" y="-110" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ProvideBiometrics_di" bpmnElement="Task_ProvideBiometrics">
        <dc:Bounds x="1200" y="-40" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_BiometricCheck_di" bpmnElement="Gateway_BiometricCheck" isMarkerVisible="true">
        <dc:Bounds x="1465" y="-25" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1391" y="133" width="78" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Dashboard_di" bpmnElement="EndEvent_Dashboard" isMarkerVisible="true">
        <dc:Bounds x="2562" y="152" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2549" y="102" width="62" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_FullLoginInput_di" bpmnElement="Task_FullLoginInput">
        <dc:Bounds x="385" y="30" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SupabaseAuth_di" bpmnElement="Task_SupabaseAuth">
        <dc:Bounds x="795" y="1060" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DataStoreReference_Supabase_di" bpmnElement="DataStoreReference_Supabase">
        <dc:Bounds x="425" y="1075" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="414" y="1125" width="73" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SaveSession_di" bpmnElement="Task_SaveSession">
        <dc:Bounds x="2210" y="405" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_OfflineAuth_di" bpmnElement="Task_OfflineAuth">
        <dc:Bounds x="510" y="720" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_QuickAccessType_di" bpmnElement="Gateway_QuickAccessType" isMarkerVisible="true">
        <dc:Bounds x="785" y="295" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="780" y="355" width="61" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_InputPIN_di" bpmnElement="Task_InputPIN">
        <dc:Bounds x="840" y="-150" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ClearSession_di" bpmnElement="Task_ClearSession">
        <dc:Bounds x="1800" y="575" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_PINCheck_di" bpmnElement="Gateway_PINCheck" isMarkerVisible="true">
        <dc:Bounds x="1115" y="-135" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1040" y="-137" width="78" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_OfflineHashCheck_di" bpmnElement="Gateway_OfflineHashCheck" isMarkerVisible="true">
        <dc:Bounds x="1088" y="735" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="931" y="700" width="58" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_FailOfflineNoCache_di" bpmnElement="EndEvent_FailOfflineNoCache" isMarkerVisible="true">
        <dc:Bounds x="2662" y="-28" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="2641" y="-80" width="78" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_NetworkCheck_di" bpmnElement="Gateway_NetworkCheck" isMarkerVisible="true">
        <dc:Bounds x="545" y="455" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="453.5" y="473" width="81" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_OnlineAuth_di" bpmnElement="Task_OnlineAuth">
        <dc:Bounds x="660" y="440" width="120" height="80" />
