#!/bin/bash
# ── 1. Validar archivos prohibidos o innecesarios ───────────────────────
PATRONES_PROHIBIDOS="(\.env|node_modules/|local\.properties|/build/|\.obsidian/|\.history/|\.DS_Store|Thumbs\.db)"
ARCHIVOS_PROHIBIDOS=$(git diff --cached --name-only | grep -E "$PATRONES_PROHIBIDOS" | grep -v "\.env\.example" || true)

if [ -n "$ARCHIVOS_PROHIBIDOS" ]; then
  echo -e "\033[0;31m❌ ERROR: Se detectaron archivos innecesarios o sensibles listos para commit:\033[0m"
  echo "$ARCHIVOS_PROHIBIDOS" | sed 's/^/   - /'
  echo -e "\033[0;33mPor favor, retíralos usando: git restore --staged <archivo>\033[0m"
  echo -e "\033[0;33mAsegúrate de que estén correctamente configurados en el .gitignore.\033[0m"
  exit 1
fi

# ── 2. Regeneración de Documentación ───────────────────────────────────

echo -e "\033[0;34m⚓ BRISMAR — Regenerando documentación de Obsidian...\033[0m"

# Ejecutar el actualizador
bash scripts/actualizar_docs.sh

# Agregar los archivos autogenerados al commit actual
git add docs/00_Dashboard/DASHBOARD.md
git add docs/01_Arquitectura/MAPA_ARQUITECTURA.md

echo -e "\033[0;32m✓ Documentación de Obsidian actualizada y agregada al commit.\033[0m"
