# ===========================
# BRISMAR_APP — Root .gitignore
# ===========================

# ── Node.js / Backend ────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
.env
.env.local
.env.*.local
CREDENCIALES_MAESTRAS.env
CREDENCIALES_MAESTRAS.md

# ── Flutter / Dart ───────────────────────────
**/build/
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.pub-cache/
**/.pub/
**/doc/api/
**/ios/Flutter/.last_build_id
**/coverage/

# ── Android Studio / Gradle ──────────────────
**/android/app/debug
**/android/app/profile
**/android/app/release
**/.gradle/
**/local.properties
**/android/key.properties

# ── Symbolication / Obfuscation ─────────────
app.*.symbols
app.*.map.json

# ── IDE ──────────────────────────────────────
.idea/
.vscode/
.history/
*.iml
*.ipr
*.iws

# ── OS ───────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ── Misc / Auto-generados ────────────────────
*.log
*.pyc
*.class
graphify-out/

# NOTA: NO ignoramos .obsidian para que las configuraciones del graph de Obsidian se sincronicen en el repo.
.obsidian/

# ── Credenciales y Claves Privadas ──────────────────
.credenciales/

